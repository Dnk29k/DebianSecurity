#
# wm independent hotkeys
#

# terminal emulator
super + Return
    /opt/kitty/bin/kitty

# program launcher
super + d
    /usr/bin/rofi -show run

# make sxhkd reload its configuration files:
super + Escape
    pkill -USR1 -x sxhkd

#
# bspwm hotkeys
#

# quit/restart bspwm (Cambiado a 'r' para no chocar con cerrar ventana)
super + shift + r
    bspc wm -r

# quit bspwm (Cerrar sesión)
super + alt + q
    bspc quit

# close and kill (super + q cierra, super + shift + q mata proceso)
super + {_,shift + }q
    bspc node -{c,k}

# alternate between the tiled and monocle layout
super + m
    bspc desktop -l next

#
# state/flags
#

# set the window state (Quitamos shift + f de aquí para dejarlo a Firefox)
super + {t,shift + t,s,f}
    bspc node -t {tiled,pseudo_tiled,floating,fullscreen}

# focus/swap
# focus the node in the given direction
super + {Left,Down,Up,Right}
    bspc node -f {west,south,north,east}

# focus the next/previous window in the current desktop
super + {_,shift + }c
    bspc node -f {next,prev}.local.!hidden.window

# focus or send to the given desktop
super + {_,shift + }{1-9,0}
    bspc {desktop -f,node -d} '^{1-9,10}'

#
# move/resize
#

# Move a floating window
super + shift + {Left,Down,Up,Right}
    bspc node -v {-20 0,0 20,0 -20,20 0}

# Custom Resize (Usando $HOME para universalidad)
super + alt + {Left,Down,Up,Right}
    $HOME/.config/bspwm/scripts/bspwm_resize {west,south,north,east}

#
# Apps
#

# Open Firefox (Ahora sin conflictos)
super + shift + f
    /usr/bin/firefox

# i3lock-fancy
super + shift + x
    /usr/bin/i3lock-fancy
